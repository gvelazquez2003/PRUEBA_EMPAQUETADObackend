# Variables de entorno para PostgreSQL en SPanel y Render.
# No guardes claves reales en este archivo.
PORT=3001

# Usuario asignado a la base admin01_neondbfinal en SPanel.
# No anadas ?sslmode=...: DB_SSL controla TLS en el backend.
DATABASE_URL=postgresql://admin01_pasante:CAMBIAR_CLAVE@174.136.57.19:5432/admin01_neondbfinal
DB_SSL=false
DB_CONNECT_TIMEOUT_MS=10000
DB_POOL_MAX=5

NODE_ENV=production
ADMIN_KEY=CAMBIAR_CLAVE_ADMIN
CORS_ORIGIN=https://produccionpdt.com,https://www.produccionpdt.com,https://prueba-empaquetad-ofrontend-theta.vercel.app

# Rutas / VRP
# Para usar OpenRouteService gratis en vez de Google Routes API.
ROUTING_PROVIDER=openrouteservice
OPENROUTESERVICE_API_KEY=CAMBIAR_API_KEY

# Compatibilidad opcional si quieres volver temporalmente a Google.
# GOOGLE_MAPS_SERVER_API_KEY=
# GOOGLE_MAPS_BROWSER_API_KEY=
# GOOGLE_MAPS_API_KEY=
